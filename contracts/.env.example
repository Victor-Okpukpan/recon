MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
# Deployer key: prefer `cast wallet import monad-deployer --private-key <key>` (keystore)
# over a raw private key here. Only set this if you're not using the keystore flow.
# DEPLOYER_PRIVATE_KEY=

# Required by script/Deploy.s.sol — the per-market unlock price in USD cents (e.g. 5 = $0.05).
# No default on purpose: this is a product decision, not something the script should guess.
PRICE_USD_CENTS=
